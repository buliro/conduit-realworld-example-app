# Copy this file to docker/.env before running docker compose.
# Public DNS name that points to the Ubuntu server.
DOMAIN=example.com

# Email address used for Let's Encrypt account registration and expiry notices.
CERTBOT_EMAIL=admin@example.com

# SSL mode:
# - letsencrypt: use Certbot to request and renew public certificates.
# - self-signed: create a local/self-managed certificate for dev or pre-DNS smoke tests.
SSL_MODE=letsencrypt

# PostgreSQL database name and user.
POSTGRES_DB=conduit_production
POSTGRES_USER=conduit

# File-based secrets are preferred over plain environment variables.
# Create these files locally with chmod 600 and do not commit them.
POSTGRES_PASSWORD_FILE=./secrets/postgres_password.txt
JWT_KEY_FILE=./secrets/jwt_key.txt

# Backend database logging passed to Sequelize.
# Use false in production unless you need SQL debugging.
PROD_DB_LOGGING=false

# Optional compose project name so container names stay predictable.
COMPOSE_PROJECT_NAME=conduit
